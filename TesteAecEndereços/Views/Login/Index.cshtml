
@{
    ViewData["Title"] = "View";
}

<h1>View</h1>

@{
    ViewData["Title"] = "Login - AEC";
}

<div class="row justify-content-center" style="margin-top: 100px;">
    <div class="col-md-4 shadow p-4 rounded bg-light">
        <h3 class="text-center mb-4">Sistema de Endereços</h3>
        
        <form method="post" action="/Login/Entrar">
            
            <div class="form-group mb-3">
                <label>Login:</label>
                <input type="text" name="usuarioDigitado" class="form-control" required placeholder="Digite seu usuário..." />
            </div>

            <div class="form-group mb-4">
                <label>Senha:</label>
                <input type="password" name="senhaDigitada" class="form-control" required placeholder="Digite sua senha..." />
            </div>

            <button type="submit" class="btn btn-primary w-100">Entrar no Sistema</button>

            @if (TempData["MensagemErro"] != null)
            {
                <div class="alert alert-danger mt-3 text-center">
                    @TempData["MensagemErro"]
                </div>
            }
        </form>
    </div>
</div>